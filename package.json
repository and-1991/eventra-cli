{
  "name": "@eventra_dev/eventra-cli",
  "version": "0.3.6",
  "description": "Static analytics event extraction CLI powered by the TypeScript compiler API",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "eventra": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/and-1991/eventra-cli"
  },

  "homepage": "https://eventra.dev",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "tsx tests/run.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "commander": "^11.0.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.7",
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.0.0",
    "cross-spawn": "^7.0.6",
    "tsx": "^4.7.0"
  },
  "keywords": [
    "analytics",
    "event-tracking",
    "static-analysis",
    "typescript",
    "compiler-api",
    "ast",
    "cli",
    "telemetry",
    "eventra"
